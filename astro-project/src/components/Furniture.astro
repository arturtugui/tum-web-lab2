---
import furnitureData from "../data/furniture.json";

const {
  heading,
  "button-label": buttonLabel,
  "button-text": buttonText,
  items,
} = furnitureData;
---

<div
  id="furniture-section"
  class="text-[aliceblue] bg-furniture-bg py-8 px-4 flex flex-col items-center"
>
  <div class="text-[1.875rem] font-bold mb-4 text-center">
    <h2 class="leading-relaxed">{heading}</h2>
  </div>

  <!-- Flex grid adapts: 1 col → 2 col (md) → 3 col (desktop)
       If < 3 items, they stretch and center naturally -->
  <div
    id="furniture-container"
    class="flex flex-wrap justify-center gap-4 w-full max-w-300 mt-4"
  >
    {
      items.map((item) => (
        <img
          src={item.src}
          alt={item.alt}
          class="w-full md:w-[calc(50%-1rem)] desktop:w-[calc(33.333%-1rem)] h-auto rounded-lg shadow-md object-cover bg-white"
        />
      ))
    }
  </div>

  <!-- md:hidden: replaces @media(min-width:768px){display:none!important}
             This wrapper is mobile-only -->
  <div
    id="furniture-button-wrapper"
    class="w-full flex gap-4 mt-6 items-center md:hidden"
  >
    <div class="flex-1 text-[1.25rem] text-[aliceblue] text-center font-bold">
      {buttonLabel}
    </div>
    <a
      href="#footer"
      id="furniture-button"
      class="w-auto min-w-[10rem] max-w-[15rem] py-2.5 px-6 rounded-xl bg-bluer-almost-dark text-white text-[1.25rem] border-none cursor-pointer shadow-md block self-center flex-1 transition-colors duration-300 hover:bg-button-hover no-underline"
    >
      {buttonText}
    </a>
  </div>
</div>
