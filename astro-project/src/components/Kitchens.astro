<div
  id="kitchens-section"
  class="grid gap-8 bg-kitchen-bg text-[aliceblue] py-8 px-4 relative place-items-center"
>
  <!-- Replaces .kitchens-heading (keeps class for grid-area targeting in input.css) -->
  <div class="kitchens-heading text-[1.875rem] font-bold text-center">
    <h2>Modele de Bucătării</h2>
  </div>

  <div class="kitchens-description text-base text-text-gray text-center">
    <h3>Modele disponibile gata de montaj sau personalizate pe comandă.</h3>
  </div>

  <!-- Kitchen CTA button: all visual styles as utilities
             Grid-area assignment handled in input.css -->
  <a
    href="#footer"
    id="kitchen-button"
    class="w-auto min-w-[10rem] max-w-[15rem] py-2.5 px-6 rounded-xl bg-bluer-almost-dark text-white text-[1.25rem] border-none cursor-pointer shadow-md shrink-0 whitespace-nowrap self-center transition-colors duration-300 hover:bg-button-hover no-underline"
  >
    Comandă acum
  </a>

  <!-- Kitchen images: visual styles as utilities, grid-area in input.css -->
  <img
    src="/images/bucatarii/b5.jpg"
    alt="Kitchen 5"
    id="kitchen-image-5"
    class="w-full h-auto rounded-lg shadow-md object-cover"
  />
  <img
    src="/images/bucatarii/b1.jpg"
    alt="Kitchen 1"
    id="kitchen-image-1"
    class="w-full h-auto rounded-lg shadow-md object-cover"
  />
  <img
    src="/images/bucatarii/b3.jpg"
    alt="Kitchen 3"
    id="kitchen-image-3"
    class="w-full h-auto rounded-lg shadow-md object-cover"
  />
  <img
    src="/images/bucatarii/b2.jpg"
    alt="Kitchen 2"
    id="kitchen-image-2"
    class="w-full h-auto rounded-lg shadow-md object-cover"
  />
  <img
    src="/images/bucatarii/b4.jpg"
    alt="Kitchen 4"
    id="kitchen-image-4"
    class="w-full h-auto rounded-lg shadow-md object-cover"
  />
</div>
