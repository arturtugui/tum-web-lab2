---
import servicesData from "../data/services.json";

const { heading, items } = servicesData;
---

<div id="services-section">
  <div class="text-[1.875rem] font-bold text-center mt-8">
    <h2>{heading}</h2>
  </div>

  <!-- Grid adapts: 1 col → 2 col (md) → 4 col (desktop)
       If < 4 items, they stretch to fill width naturally -->
  <div
    id="services-container"
    class="grid grid-cols-1 md:grid-cols-2 desktop:grid-cols-4 gap-8 items-center mt-6 mb-6 mx-4 pb-4"
  >
    {
      items.map((service) => (
        <div class="bg-white rounded-2xl shadow-md py-8 px-4 text-center flex flex-col items-center justify-start">
          <i class={`fas ${service.icon} fa-3x`} />
          <hr class="w-[10%] border-0 border-t border-vivid-blue my-2" />
          <div class="text-[1.25rem] font-bold mb-4">
            <h3>{service.title}</h3>
          </div>
          <div class="text-base text-muted-gray-blue grow">
            <h4>{service.description}</h4>
          </div>
        </div>
      ))
    }
  </div>
</div>
